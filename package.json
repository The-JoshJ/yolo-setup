{
  "name": "@acme/yolo-setup",
  "version": "0.1.0",
  "description": "YOLO Setup CLI - automated developer onboarding",
  "type": "module",
  "main": "src/cli/index.ts",
  "bin": {
    "yolo": "dist/cli.cjs"
  },
  "scripts": {
    "start": "tsx src/cli/index.ts",
    "build": "esbuild src/cli/index.ts --bundle --platform=node --format=cjs --outfile=dist/cli.cjs --banner:js='#!/usr/bin/env node' --external:fsevents",
    "prepare": "npm run build",
    "dev": "tsx watch src/cli/index.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.4.0",
    "chalk": "^5.4.1",
    "execa": "^9.5.2",
    "figlet": "^1.8.0",
    "globby": "^14.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ora": "^9.4.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.19.17",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2"
  }
}
